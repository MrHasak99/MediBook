# ============================================================
# MediBook Server — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server port (defaults to 5000 if not set)
PORT=5000

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — KEEP SECRET, never expose to the client
# (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Frontend origin for CORS — set to your Netlify URL in production
# e.g. https://your-app.netlify.app
FRONTEND_URL=http://localhost:5500
